{
  "name": "release-quest",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Multiplayer bug-catching arcade game",
  "scripts": {
    "start": "node server.ts",
    "build": "node build.mjs",
    "dev": "node build.mjs --watch",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.client.json",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --type-aware --fix"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "bcrypt": "6.0.0",
    "express": "5.2.1",
    "pg": "8.20.0",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "prom-client": "15.1.3",
    "ws": "8.19.0",
    "zod": "4.3.6"
  },
  "overrides": {
    "tar": "7.5.11"
  },
  "devDependencies": {
    "@types/bcrypt": "6.0.0",
    "@types/express": "5.0.6",
    "@types/node": "24.12.0",
    "@types/pg": "8.20.0",
    "@types/ws": "8.18.1",
    "esbuild": "0.27.3",
    "oxlint": "1.56.0",
    "oxlint-tsgolint": "0.17.1",
    "typescript": "5.9.3"
  }
}
